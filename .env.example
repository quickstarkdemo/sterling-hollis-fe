# API Configuration
# Leave VITE_API_URL empty to use the same-origin /api proxy in local dev and Nginx.
VITE_API_URL=
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_DEFAULT_STORE_ID=
VITE_CLERK_PUBLISHABLE_KEY=

# Environment
VITE_ENVIRONMENT=development

# Datadog browser monitoring is optional.
VITE_DATADOG_APPLICATION_ID=
VITE_DATADOG_CLIENT_TOKEN=
VITE_DATADOG_SITE=datadoghq.com
VITE_DATADOG_SERVICE=sterling-hollis-fe

# Docker/deploy settings
DOCKERHUB_USER=
DOCKERHUB_TOKEN=
DOCKERHUB_IMAGE=quickstark/sterling-hollis-fe
FRONTEND_PORT=3000
